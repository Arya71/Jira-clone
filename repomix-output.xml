      })
      .finally(() => setIsRedirecting(false));
  };

  const isPending = isLoggingIn || isRedirecting;

  return (
    <Card className="size-full border-none shadow-none md:w-[487px]">
      <CardHeader className="flex items-center justify-center p-7 text-center">
